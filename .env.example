ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://trip-guard-ai.vercel.app
STREAM_STEP_DELAY_SECONDS=0.35

# Backend-only live travel credentials
SERPAPI_API_KEY=

# local or serpapi
TRAVEL_PROVIDER_MODE=local

# Use JSON inventory when live search fails
TRAVEL_FALLBACK_TO_LOCAL=true

SERPAPI_REQUEST_TIMEOUT_SECONDS=30
SERPAPI_MAX_FLIGHT_RESULTS=8
SERPAPI_MAX_HOTEL_RESULTS=8